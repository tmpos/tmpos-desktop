# Hostinger API Configuration
# Obtén tu token en: https://hpanel.hostinger.com/profile/api
VITE_HOSTINGER_API_TOKEN=tu_token_aqui
VITE_HOSTINGER_API_BASE_URL=https://developers.hostinger.com/api

# VPS ID (opcional, para acceso rápido)
VITE_HOSTINGER_VPS_ID=

# Dominio principal (opcional)
VITE_HOSTINGER_DOMAIN=

# Supabase Configuration
# Configuración de Supabase en el VPS
# Obtén las claves en: Settings → API en tu dashboard de Supabase
VITE_SUPABASE_URL=https://srv1794803.hstgr.cloud
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui
VITE_SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key_aqui
