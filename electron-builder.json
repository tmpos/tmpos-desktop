{
  "appId": "com.tmpos.app",
  "productName": "TMPOS",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "dist-electron/main.js",
    "dist-electron/preload.js"
  ],
  "extraResources": [
    {
      "from": "build/tmpos-windows.ico",
      "to": "tmpos-windows.ico"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/tmpos-valid.ico",
    "artifactName": "${productName}.Setup.${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true
  }
}
