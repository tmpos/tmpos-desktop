{
  "appId": "com.tmpos.app",
  "productName": "TMPOS",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true
  }
}
