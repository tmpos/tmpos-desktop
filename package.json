    "astral-regex": "^2.0.0",
    "autoprefixer": "^10.5.0",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^1.0.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
