{
  "name": "TMPOS",
  "version": "2.11.1",
  "description": "TMPOS Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite --mode electron",
    "electron:start": "vite build --mode electron && esbuild electron/main.ts --bundle --platform=node --outfile=dist-electron/main.js --external:electron --external:better-sqlite3 --format=cjs && esbuild electron/preload.ts --bundle --platform=node --outfile=dist-electron/preload.js --external:electron --format=cjs && electron dist-electron/main.js",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "electron:build": "npm run rebuild:native && vite build && electron-builder",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:build": "vite build && npx cap sync",
    "cap:dev": "vite build && npx cap sync && npx cap run android"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/network": "^6.0.4",
    "@primevue/icons": "^4.5.5",
    "@primevue/themes": "^4.5.4",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qrcode": "^1.5.4",
    "slice-ansi": "^8.0.0",
    "sql.js": "^1.14.1",
    "sweetalert2": "^11.26.24",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.2.4",
